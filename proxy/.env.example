SAP_SL_URL=https://sapserver:50000/b1s/v2
SAP_COMPANY_DB=YOUR_COMPANY_DB
SAP_USERNAME=api_receiving
SAP_PASSWORD=your_password
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
CORS_ORIGIN=https://localhost:5173,https://dgoelztork.github.io
JWT_SECRET=change_this_to_a_long_random_string
PORT=3001
NODE_TLS_REJECT_UNAUTHORIZED=0
ALLOWED_EMAIL_DOMAIN=yourdomain.com
ALLOWED_USERS=
# Optional. If unset, /api/extract/* endpoints return 503; everything else still works.
ANTHROPIC_API_KEY=

# Optional. UPS Rating API (server-to-server OAuth).
# If UPS_CLIENT_ID is unset, /api/freight/ups-rate returns 503 and the PWA
# silently skips rate lookup. UPS_BASE_URL: https://wwwcie.ups.com for the
# testing sandbox (CIE), https://onlinetools.ups.com for production.
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ACCOUNT_NUMBER=
UPS_BASE_URL=https://onlinetools.ups.com
UPS_DEST_ZIP=
